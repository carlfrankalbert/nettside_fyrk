---
import ToolLayout from '../layouts/ToolLayout.astro';
import OKRPageContent from '../components/OKRPageContent';
import { okrTool } from '../data/tools';

const { seo, toolName, breadcrumbLabel, h1, subtitle, disclaimer, whenToUse, benefits, relatedTools, mobileCTA } = okrTool.page;

const faqItems = [
  {
    question: 'Hva er OKR?',
    answer: 'OKR (Objectives and Key Results) er et rammeverk for målstyring. Et Objective beskriver hva du vil oppnå, mens Key Results er målbare resultater som viser om du er på vei.',
  },
  {
    question: 'Hvordan skriver jeg gode OKR-er?',
    answer: 'Et godt Objective er kvalitativt, inspirerende og tidsbegrenset. Key Results skal være målbare, ambisiøse men oppnåelige, og direkte knyttet til Objective. Unngå å liste opp aktiviteter — fokuser på utfall.',
  },
  {
    question: 'Er OKR-sjekken gratis?',
    answer: 'Ja. OKR-sjekken er helt gratis og krever ingen registrering. Du limer inn OKR-settet ditt og får en AI-drevet vurdering med score, styrker og forbedringsforslag.',
  },
  {
    question: 'Lagres OKR-ene mine?',
    answer: 'Nei. OKR-ene du limer inn brukes kun til å generere vurderingen og lagres ikke. Unngå likevel å lime inn konfidensiell informasjon.',
  },
];

---

<ToolLayout
  title={seo.title}
  description={seo.description}
  toolName={toolName}
  breadcrumbLabel={breadcrumbLabel}
  whenToUse={whenToUse}
  benefits={benefits}
  relatedTools={relatedTools}
  mobileCTA={mobileCTA}
>
  <header slot="hero" class="mb-8">
    <h1 class="text-h3 md:text-h2 font-semibold text-brand-navy mb-3 leading-tight">
      {h1}
    </h1>
    <p class="text-base md:text-lg text-neutral-600 leading-relaxed">
      {subtitle}
    </p>
    <p class="text-sm md:text-base text-neutral-500 italic mt-1">
      {disclaimer}
    </p>
  </header>

  <OKRPageContent client:load />

  <section slot="seo-content" class="mt-16 border-t border-neutral-200 pt-12 space-y-10">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    })} />

    <div>
      <h2 class="text-xl font-semibold text-brand-navy mb-3">Hva er OKR?</h2>
      <p class="text-neutral-600 leading-relaxed">
        OKR (Objectives and Key Results) er et rammeverk for målstyring brukt av selskaper som Google, Spotify og DNB. Et <strong>Objective</strong> beskriver hva du vil oppnå — kvalitativt og inspirerende. <strong>Key Results</strong> er 2–5 målbare resultater som viser om du er på vei mot målet.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-brand-navy mb-3">Slik bruker du OKR-sjekken</h2>
      <ol class="list-decimal list-inside text-neutral-600 leading-relaxed space-y-2">
        <li>Skriv eller lim inn ditt Objective og tilhørende Key Results.</li>
        <li>Trykk «Sjekk OKR-settet ditt» for å få en AI-drevet vurdering.</li>
        <li>Les gjennom score, styrker og forbedringsforslag.</li>
        <li>Juster OKR-ene basert på tilbakemeldingen og test gjerne på nytt.</li>
      </ol>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-brand-navy mb-4">Vanlige spørsmål</h2>
      <dl class="space-y-4">
        {faqItems.map((faq) => (
          <div>
            <dt class="font-medium text-neutral-700">{faq.question}</dt>
            <dd class="text-neutral-600 mt-1">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</ToolLayout>

<script>
  import { initPageViewTracking } from '../scripts/pageview-tracking';
  import { initTrackingHelpers } from '../scripts/tracking-exclusion';
  import { initMobileCTA } from '../scripts/mobile-cta';
  initPageViewTracking('okr');
  initTrackingHelpers();
  initMobileCTA({
    toolName: 'okr',
    isDisabled: (d) => !!d.isLoading,
    loadingText: 'Vurderer OKR-ene...',
    defaultHtml: `<span>Sjekk OKR-settet</span><svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>`,
  });
</script>
