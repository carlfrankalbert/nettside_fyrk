---
/**
 * Innsikt detail page
 * Renders a single insight text
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const insights = await getCollection('innsikt', ({ data }) => !data.draft);
  return insights.map((insight) => ({
    params: { slug: insight.slug },
    props: { insight },
  }));
}

interface Props {
  insight: CollectionEntry<'innsikt'>;
}

const { insight } = Astro.props;
const { Content } = await insight.render();

const canonicalUrl = `https://fyrk.no/innsikt/${insight.slug}/`;

const formattedDate = insight.data.date.toLocaleDateString('nb-NO', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const isoDate = insight.data.date.toISOString().slice(0, 10);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: insight.data.title,
  description: insight.data.excerpt,
  datePublished: isoDate,
  author: {
    '@type': 'Person',
    name: insight.data.author,
    url: 'https://fyrk.no',
  },
  publisher: { '@id': 'https://fyrk.no/#organization' },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  inLanguage: 'nb-NO',
};
---

<BaseLayout
  title={insight.data.title}
  description={insight.data.excerpt}
  type="article"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  <article class="py-16 md:py-24 px-6">
    <div class="max-w-3xl mx-auto">

      <a href="/innsikt/" class="text-sm text-neutral-500 hover:text-brand-navy transition-colors no-underline mb-8 inline-block">
        &larr; Tilbake til innsikt
      </a>

      <header class="mb-10">
        {insight.data.category && (
          <span class="inline-block text-xs font-medium uppercase tracking-wide text-brand-cyan-darker mb-3">
            {insight.data.category}
          </span>
        )}
        <h1 class="text-h2 md:text-h1 font-semibold text-brand-navy mb-4 leading-tight">
          {insight.data.title}
        </h1>
        <p class="text-xl text-neutral-600 leading-relaxed">
          {insight.data.excerpt}
        </p>
        <p class="mt-6 text-sm text-neutral-500">
          Av {insight.data.author} · Publisert <time datetime={isoDate}>{formattedDate}</time>
        </p>
      </header>

      <div class="prose prose-neutral max-w-none innsikt-prose">
        <Content />
      </div>

      {insight.data.summary && (
        <section class="mt-16 rounded-lg bg-neutral-50 border border-neutral-200 p-6 md:p-8">
          <h2 class="text-h5 font-semibold text-brand-navy mb-3">
            Kort forklart
          </h2>
          <p class="text-neutral-700 leading-relaxed">
            {insight.data.summary}
          </p>
        </section>
      )}

      {insight.data.closing && (
        <aside class="mt-10 pt-8 border-t border-neutral-200 text-sm text-neutral-500 leading-relaxed">
          {insight.data.closing}
        </aside>
      )}

    </div>
  </article>
</BaseLayout>

<style is:global>
  .innsikt-prose ul,
  .innsikt-prose ol {
    margin-top: 2.25em;
    margin-bottom: 2.25em;
    padding-left: 1.5em;
  }
  .innsikt-prose ul {
    list-style-type: disc;
  }
  .innsikt-prose ol {
    list-style-type: decimal;
  }
  .innsikt-prose ul > li,
  .innsikt-prose ol > li {
    margin-top: 0.85em;
    margin-bottom: 0.85em;
    padding-left: 0.25em;
    line-height: 1.7;
  }
  .innsikt-prose ul > li::marker,
  .innsikt-prose ol > li::marker {
    color: rgb(107 122 148);
  }
</style>
