---
/**
 * Test Environment - IP Whitelisted
 * 
 * Denne siden viser full site, men er kun tilgjengelig for whitelisted IP-adresser.
 * 
 * IP Whitelisting:
 * - Sett PUBLIC_WHITELISTED_IPS environment variable med komma-separerte IP-adresser
 * - Eksempel: PUBLIC_WHITELISTED_IPS=123.45.67.89,98.76.54.32
 * 
 * Hvis IP ikke er whitelisted, vises en "Access Denied" melding.
 */
import '../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Section from '../../components/Section.astro';
import CTASection from '../../components/CTASection.astro';
import FeatureList from '../../components/FeatureList.astro';
import AccentLine from '../../components/AccentLine.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ButtonGroup from '../../components/ButtonGroup.astro';
import { services } from '../../data/services';
import { targetAudience } from '../../data/targetAudience';
import { textClasses, cn } from '../../utils/classes';

// Hent whitelisted IPs fra environment variable
const whitelistedIPs = import.meta.env.PUBLIC_WHITELISTED_IPS 
  ? import.meta.env.PUBLIC_WHITELISTED_IPS.split(',').map(ip => ip.trim())
  : [];
---

<BaseLayout 
  title="Test Miljø" 
  description="Fyrk testmiljø - Full site preview"
>
  <!-- IP Whitelisting Check -->
  <div id="ip-check" style="display: none;">
    <div class="min-h-screen flex items-center justify-center bg-neutral-50 dark:bg-neutral-900">
      <div class="text-center max-w-md mx-auto p-8">
        <h1 class={cn('text-2xl font-bold mb-4', textClasses.primary)}>
          Tilgang begrenset
        </h1>
        <p class={cn('text-lg', textClasses.secondary)}>
          Denne siden er kun tilgjengelig for autoriserte IP-adresser.
        </p>
      </div>
    </div>
  </div>

  <!-- Full Site Content (skjult til IP er verifisert) -->
  <div id="site-content">
    <!-- Hero Section -->
    <Section background="gradient" ariaLabelledBy="hero-heading" padding="large">
      <div class="max-w-5xl mx-auto text-center">
        <AccentLine />
        
        <h1 id="hero-heading" class={cn('text-display md:text-[4rem] lg:text-[5rem] font-bold', textClasses.primary, 'mb-6 md:mb-10 leading-[1.1] tracking-tight')}>
          Produktledelse som <span class="text-brand-cyan-darker dark:text-brand-cyan">leverer</span> forretningsverdi
        </h1>
        <p class={cn('text-lg md:text-xl lg:text-2xl', textClasses.secondary, 'mb-8 md:mb-12 leading-relaxed max-w-[70ch] mx-auto font-light')}>
          Vi hjelper organisasjoner å få mennesker, prosesser og teknologi til å virke sammen for å skape produkter som virker – raskt, trygt og med reell brukerverdi.
        </p>
        
        <ButtonGroup 
          buttons={[
            {
              text: 'Snakk med oss',
              href: '/kontakt',
              variant: 'primary',
              ariaLabel: 'Snakk med oss fra Fyrk'
            },
            {
              text: 'Les mer om oss',
              href: '/om',
              variant: 'outline',
              ariaLabel: 'Les mer om Fyrk'
            }
          ]}
        />
      </div>
    </Section>

    <!-- Services Section -->
    <Section background="white" ariaLabelledBy="services-heading">
      <SectionHeader 
        heading="Hva vi tilbyr"
        headingId="services-heading"
        description="Vi leverer produktledelse som leverer, teambygging og trygg leveranse for organisasjoner som trenger både hastighet og soliditet."
        headingLevel={2}
        class="mb-20 md:mb-32"
      />
      
      <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr] gap-8 md:gap-16 max-w-7xl mx-auto">
        {services.map((service, index) => (
          <ServiceCard
            icon={service.icon}
            title={service.title}
            description={service.description}
            featured={index === 0}
          />
        ))}
      </div>
    </Section>

    <!-- Who We Help Section -->
    <Section background="neutral" ariaLabelledBy="who-we-help-heading">
      <FeatureList 
        heading="Passer for selskaper som:" 
        items={targetAudience}
        headingId="who-we-help-heading"
      />
    </Section>

    <!-- CTA Section -->
    <CTASection
      heading="Klar til å starte?"
      description="Ta kontakt for å høre hvordan vi kan hjelpe ditt selskap med produktledelse som faktisk leverer resultater."
      buttonText="Snakk med oss"
      buttonHref="/kontakt"
      buttonAriaLabel="Snakk med oss fra Fyrk"
      variant="secondary"
    />
  </div>

  <script define:vars={{ whitelistedIPs }}>
    // IP Whitelisting Check
    (function() {
      const whitelistedIPsArray = whitelistedIPs || [];
      const ipCheckEl = document.getElementById('ip-check');
      const siteContentEl = document.getElementById('site-content');

      // Hvis ingen IPs er whitelisted, vis alltid innholdet (for utvikling)
      if (whitelistedIPsArray.length === 0) {
        if (ipCheckEl) ipCheckEl.style.display = 'none';
        if (siteContentEl) siteContentEl.style.display = 'block';
        return;
      }

      // Hent brukerens IP-adresse
      fetch('https://api.ipify.org?format=json')
        .then(response => response.json())
        .then(data => {
          const userIP = data.ip;
          const isWhitelisted = whitelistedIPsArray.includes(userIP);

          if (isWhitelisted) {
            // IP er whitelisted - vis innhold
            if (ipCheckEl) ipCheckEl.style.display = 'none';
            if (siteContentEl) siteContentEl.style.display = 'block';
          } else {
            // IP er ikke whitelisted - vis "Access Denied"
            if (ipCheckEl) ipCheckEl.style.display = 'block';
            if (siteContentEl) siteContentEl.style.display = 'none';
          }
        })
        .catch(error => {
          console.error('Error checking IP:', error);
          // Ved feil, vis "Access Denied" for sikkerhet
          if (ipCheckEl) ipCheckEl.style.display = 'block';
          if (siteContentEl) siteContentEl.style.display = 'none';
        });
    })();
  </script>
</BaseLayout>

