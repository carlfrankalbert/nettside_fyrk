---
/**
 * Services overview page
 * Lists all FYRK services with links back to landing page
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { servicesContent } from '../../data/landing';
import { EXTERNAL_LINKS, CONTACT_LABEL } from '../../utils/links';
import { tjenesterIndexContent } from '../../data/tjenester';

const { seo, title, subtitle, contactBridge } = tjenesterIndexContent;

const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: servicesContent.services.map((service, i) => ({
    '@type': 'Service',
    position: i + 1,
    name: service.title,
    description: service.description,
    provider: {
      '@type': 'LocalBusiness',
      '@id': 'https://fyrk.no/#organization',
      name: 'FYRK',
      url: 'https://fyrk.no',
    },
    areaServed: { '@type': 'Country', name: 'NO' },
    availableLanguage: 'nb',
  })),
});
---

<BaseLayout
  title={seo.title}
  description={seo.description}
>
  <script type="application/ld+json" set:html={serviceSchema} />
  <article class="py-16 md:py-24 px-6">
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <header class="mb-16">
        <h1 class="text-h2 md:text-h1 font-semibold text-brand-navy mb-4 leading-tight">
          {title}
        </h1>
        <p class="text-xl md:text-2xl text-neutral-600 leading-relaxed">
          {subtitle}
        </p>
      </header>

      <!-- Services -->
      <div class="space-y-6 mb-10">
        {servicesContent.services.map((service) => (
          <div class="block rounded-lg border bg-white text-neutral-700 border-neutral-200 shadow-sm p-6 md:p-8">
            <h2 class="text-h4 font-semibold text-brand-navy mb-2 hyphens-auto">
              {service.title}
            </h2>
            <p class="text-neutral-600 mb-2">
              {service.description}
            </p>
            <p class="text-sm italic text-neutral-500">
              Passer når: {service.fitWhen}
            </p>
          </div>
        ))}
      </div>

      <!-- Contact bridge -->
      <section class="bg-neutral-50 rounded-lg p-8 md:p-10 border border-neutral-200">
        <h2 class="text-h4 font-semibold text-brand-navy mb-3">{contactBridge.heading}</h2>
        <p class="text-neutral-600 mb-6">
          {contactBridge.body}
        </p>
        <a href={EXTERNAL_LINKS.email} class="btn btn-primary no-underline inline-flex">{CONTACT_LABEL}</a>
      </section>

    </div>
  </article>
</BaseLayout>
