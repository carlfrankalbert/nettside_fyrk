---
/**
 * Landing page for FYRK
 * Senior produktleder og operativ rådgiver
 */

import '../styles/global.css';
import SEOHead from '../components/seo/SEOHead.astro';
import { ELEMENT_IDS } from '../utils/constants';

// Landing page components
import LandingHeader from '../components/landing/LandingHeader.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import IntroSection from '../components/landing/IntroSection.astro';
import ContributionsSection from '../components/landing/ContributionsSection.astro';
import WhenFitsSection from '../components/landing/WhenFitsSection.astro';
import ExperienceSection from '../components/landing/ExperienceSection.astro';
import AboutSection from '../components/landing/AboutSection.astro';
import FaqSection from '../components/landing/FaqSection.astro';
import ContactSection from '../components/landing/ContactSection.astro';
import TestimonialsSection from '../components/landing/TestimonialsSection.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';

// Content data
import {
  navLinks,
  heroContent,
  introContent,
  contributionsContent,
  whenFitsContent,
  experienceContent,
  aboutContent,
  faqContent,
  testimonialsContent,
  contactContent,
  footerContent,
} from '../data/landing';

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://fyrk.no/#carl-johnson',
  name: 'Carl Johnson',
  url: 'https://fyrk.no',
  jobTitle: 'Senior produktleder og operativ rådgiver',
  sameAs: ['https://www.linkedin.com/in/carlfajohnson/'],
  worksFor: { '@id': 'https://fyrk.no/#organization' },
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqContent.items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<!doctype html>
<html lang="no" class="scroll-smooth">
  <head>
    <SEOHead
      title="Senior produktleder og operativ rådgiver"
      description="FYRK bistår komplekse og regulerte produktmiljøer med prioritering, roadmap, avhengigheter og fremdrift."
      type="website"
    />
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </head>
  <body class="min-h-screen flex flex-col bg-neutral-50 text-neutral-700">
    <!-- Skip link for accessibility -->
    <a href={`#${ELEMENT_IDS.MAIN}`} class="skip-link">Hopp til hovedinnhold</a>

    <LandingHeader navLinks={navLinks} />

    <main id={ELEMENT_IDS.MAIN} class="flex-1">
      <HeroSection {...heroContent} />

      <IntroSection paragraphs={introContent.paragraphs} />

      <ContributionsSection
        id="bidrag"
        title={contributionsContent.title}
        intro={contributionsContent.intro}
        items={contributionsContent.items}
      />

      <WhenFitsSection
        title={whenFitsContent.title}
        statement={whenFitsContent.statement}
        lead={whenFitsContent.lead}
        items={whenFitsContent.items}
      />

      <ExperienceSection
        title={experienceContent.title}
        lead={experienceContent.lead}
        entries={experienceContent.entries}
      />

      <AboutSection
        title={aboutContent.title}
        founder={aboutContent.founder}
      />

      <FaqSection title={faqContent.title} items={faqContent.items} />

      <section class="pt-4 pb-16 md:pb-20 px-6 bg-neutral-50">
        <div class="max-w-3xl mx-auto text-center text-sm text-neutral-500">
          Les også
          <a href="/innsikt/" class="text-brand-cyan-darker hover:text-brand-navy transition-colors underline underline-offset-4 mx-1">FYRKs innsikt</a>
          eller
          <a href="/verktoy/" class="text-brand-cyan-darker hover:text-brand-navy transition-colors underline underline-offset-4 mx-1">verktøy for produktledere</a>.
        </div>
      </section>

      <ContactSection {...contactContent} />

      <TestimonialsSection
        title={testimonialsContent.title}
        testimonials={testimonialsContent.testimonials}
      />
    </main>

    <LandingFooter {...footerContent} />

    <script>
      import { initMobileMenu } from '../scripts/mobile-menu';
      import { initButtonTracking } from '../scripts/button-tracking';
      import { initPageViewTracking } from '../scripts/pageview-tracking';
      import { initTrackingHelpers } from '../scripts/tracking-exclusion';
      initMobileMenu();
      initButtonTracking();
      initPageViewTracking('home');
      initTrackingHelpers();
    </script>
  </body>
</html>
