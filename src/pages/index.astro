---
/**
 * Landing page for FYRK
 * Senior product leadership for regulated industries
 */

import '../styles/global.css';
import SEOHead from '../components/seo/SEOHead.astro';
import { ELEMENT_IDS } from '../utils/constants';

// Landing page components
import LandingHeader from '../components/landing/LandingHeader.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import ServicesSection from '../components/landing/ServicesSection.astro';
import AboutSection from '../components/landing/AboutSection.astro';
import ExperienceSection from '../components/landing/ExperienceSection.astro';
import TestimonialsSection from '../components/landing/TestimonialsSection.astro';
import ContactSection from '../components/landing/ContactSection.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';

// Content data
import {
  navLinks,
  heroContent,
  servicesContent,
  aboutContent,
  experienceContent,
  testimonialsContent,
  contactContent,
  footerContent,
} from '../data/landing';
---

<!doctype html>
<html lang="no" class="scroll-smooth">
  <head>
    <SEOHead
      title="Senior produktledelse for regulerte bransjer"
      description="Interim produktleder og produktcoaching for bank, fintech og offentlig sektor. 15+ års erfaring. OKR, AI-verktøy og beslutningsstøtte."
      type="website"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'LocalBusiness',
          '@id': 'https://fyrk.no/#organization',
          name: 'FYRK',
          url: 'https://fyrk.no',
          description: 'Produktledelse og coaching for regulerte bransjer.',
          areaServed: { '@type': 'Country', name: 'NO' },
          serviceType: ['Consulting', 'Product Management', 'Coaching'],
          contactPoint: {
            '@type': 'ContactPoint',
            contactType: 'customer service',
            email: 'hei@fyrk.no',
            availableLanguage: 'Norwegian',
          },
          address: {
            '@type': 'PostalAddress',
            streetAddress: 'Møllergata 6',
            addressLocality: 'Oslo',
            postalCode: '0179',
            addressCountry: 'NO',
          },
          founder: { '@id': 'https://fyrk.no/#founder' },
        },
        {
          '@type': 'Person',
          '@id': 'https://fyrk.no/#founder',
          name: 'Carl Johnson',
          url: 'https://fyrk.no',
          jobTitle: 'Produktleder og rådgiver',
          sameAs: ['https://www.linkedin.com/in/carlfajohnson/'],
          worksFor: { '@id': 'https://fyrk.no/#organization' },
        },
      ],
    })} />
  </head>
  <body class="min-h-screen flex flex-col bg-neutral-50 text-neutral-700">
    <!-- Skip link for accessibility -->
    <a href={`#${ELEMENT_IDS.MAIN}`} class="skip-link">Hopp til hovedinnhold</a>

    <LandingHeader navLinks={navLinks} />

    <main id={ELEMENT_IDS.MAIN} class="flex-1">
      <HeroSection {...heroContent} />

      <ServicesSection
        title={servicesContent.title}
        intro={servicesContent.intro}
        services={servicesContent.services}
        footnote={servicesContent.footnote}
        ctaText={servicesContent.ctaText}
        ctaHref={servicesContent.ctaHref}
      />

      <AboutSection
        title={aboutContent.title}
        founder={aboutContent.founder}
      />

      <ExperienceSection
        title={experienceContent.title}
        entries={experienceContent.entries}
      />

      <TestimonialsSection
        title={testimonialsContent.title}
        testimonials={testimonialsContent.testimonials}
      />

      <ContactSection {...contactContent} />
    </main>

    <LandingFooter {...footerContent} />

    <script>
      import { initMobileMenu } from '../scripts/mobile-menu';
      import { initButtonTracking } from '../scripts/button-tracking';
      import { initPageViewTracking } from '../scripts/pageview-tracking';
      import { initTrackingHelpers } from '../scripts/tracking-exclusion';
      initMobileMenu();
      initButtonTracking();
      initPageViewTracking('home');
      initTrackingHelpers();
    </script>
  </body>
</html>
