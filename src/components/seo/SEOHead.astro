---
import { BRAND } from '../../utils/brand';

interface Props {
  /** Page-specific title. The site name is appended automatically unless appendSiteName=false. */
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl?: URL;
  /** Set to false when title already contains the brand name (rare). Default: true. */
  appendSiteName?: boolean;
}

const {
  title,
  description,
  image,
  type = 'website',
  canonicalUrl,
  appendSiteName = true,
} = Astro.props;

const site = Astro.site || new URL(BRAND.url);
const fullTitle = appendSiteName ? `${title} | ${BRAND.name}` : title;
const metaDescription = description || BRAND.description;
const ogImage = image ? new URL(image, site) : new URL(BRAND.ogImage, site);
const canonical = canonicalUrl || new URL(Astro.url.pathname, site);

const baseStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${BRAND.url}/#organization`,
      name: BRAND.name,
      url: BRAND.url,
      logo: `${BRAND.url}${BRAND.logo}`,
      email: BRAND.email,
      telephone: BRAND.phone,
      address: {
        '@type': 'PostalAddress',
        ...BRAND.address,
      },
      identifier: BRAND.orgNumber,
      areaServed: { '@type': 'Country', name: 'NO' },
    },
    {
      '@type': 'WebSite',
      '@id': `${BRAND.url}/#website`,
      url: BRAND.url,
      name: BRAND.name,
      inLanguage: BRAND.inLanguage,
      publisher: { '@id': `${BRAND.url}/#organization` },
    },
  ],
};
---

<meta charset="UTF-8" />
<meta name="description" content={metaDescription} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/fyrk-monogram-primary-navy.svg" />
<meta name="generator" content={Astro.generator} />
<title>{fullTitle}</title>

<!-- Resource hints for improved performance -->
<link rel="dns-prefetch" href="https://api.anthropic.com" />
<link rel="preconnect" href="https://api.anthropic.com" crossorigin />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={BRAND.locale} />
<meta property="og:site_name" content={BRAND.name} />

<!-- Twitter -->
<meta name="twitter:card" content={type === 'article' ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={metaDescription} />
{type === 'article' && <meta name="twitter:image" content={ogImage} />}

<!-- Canonical & hreflang -->
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="nb" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<!-- Organization + WebSite JSON-LD on every page -->
<script type="application/ld+json" set:html={JSON.stringify(baseStructuredData)} />
