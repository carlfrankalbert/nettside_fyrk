---
/**
 * Services section for the landing page
 * Displays 4 equal-weight service blocks with intro paragraph
 */

interface Service {
  title: string;
  description: string;
  fitWhen: string;
}

interface Props {
  title: string;
  intro: string;
  services: readonly Service[];
  footnote?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { title, intro, services, footnote, ctaText, ctaHref } = Astro.props;
---

<section id="tjenester" class="py-16 md:py-20 px-6 bg-white scroll-mt-20">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-h3 font-semibold text-brand-navy mb-4 text-center">
      {title}
    </h2>

    <p class="text-neutral-600 text-center mb-12 max-w-2xl mx-auto">
      {intro}
    </p>

    <div class="divide-y divide-neutral-200">
      {services.map((service) => (
        <div class="py-8 first:pt-0 last:pb-0">
          <h3 class="text-h4 font-semibold text-brand-navy mb-3">
            {service.title}
          </h3>
          <p class="text-neutral-600 mb-3">
            {service.description}
          </p>
          <p class="text-sm italic text-neutral-500">
            Passer når: {service.fitWhen}
          </p>
        </div>
      ))}
    </div>

    {footnote && (
      <p class="mt-8 text-sm text-neutral-500 text-center">{footnote}</p>
    )}

    {ctaText && ctaHref && (
      <div class="mt-6 text-center">
        <a href={ctaHref} class="btn btn-primary no-underline" data-track-button="services_cta">
          {ctaText}
        </a>
      </div>
    )}
  </div>
</section>
