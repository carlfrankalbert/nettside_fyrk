---
/**
 * About section for the landing page
 * Bio, certifications, and prominent LinkedIn link
 */
import { Image } from 'astro:assets';
import carlJohnsonImage from '../../assets/images/carl-johnson.jpg';

interface LinkedinCta {
  text: string;
  href: string;
}

interface Founder {
  heading: string;
  image?: string;
  paragraphs: readonly string[];
  linkedinCta: LinkedinCta;
}

interface Props {
  title: string;
  founder: Founder;
}

const { title, founder } = Astro.props;
---

<section id="om" class="py-20 md:py-28 px-6 bg-neutral-50 scroll-mt-20">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-h2 font-semibold text-brand-navy mb-3 text-center">
      {title}
    </h2>
    <div class="w-16 h-1 bg-brand-cyan-darker mx-auto mb-8"></div>

    <div>
      <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] gap-8 mb-6">
        {founder.image && (
          <div class="flex-shrink-0">
            <Image
              src={carlJohnsonImage}
              alt={founder.heading}
              width={192}
              height={192}
              class="w-32 h-32 md:w-48 md:h-48 rounded-2xl object-cover grayscale shadow-lg ring-4 ring-neutral-100"
              loading="lazy"
            />
          </div>
        )}
        <div class="flex-1 space-y-4">
          {founder.paragraphs.map((paragraph) => (
            <p class="text-neutral-600">{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="border-t border-neutral-100 pt-6">
        <a
          href={founder.linkedinCta.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-cyan-darker hover:text-brand-cyan-dark transition-colors"
          aria-label={`${founder.linkedinCta.text} (åpnes i ny fane)`}
          data-track-button="about_linkedin"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19M18.5 18.5V13.2A3.26 3.26 0 0 0 15.24 9.94C14.39 9.94 13.4 10.46 12.92 11.24V10.13H10.13V18.5H12.92V13.57C12.92 12.8 13.54 12.17 14.31 12.17A1.4 1.4 0 0 1 15.71 13.57V18.5H18.5M6.88 8.56A1.68 1.68 0 0 0 8.56 6.88C8.56 5.95 7.81 5.19 6.88 5.19A1.69 1.69 0 0 0 5.19 6.88C5.19 7.81 5.95 8.56 6.88 8.56M8.27 18.5V10.13H5.5V18.5H8.27Z"/>
          </svg>
          {founder.linkedinCta.text}
        </a>
      </div>
    </div>
  </div>
</section>
