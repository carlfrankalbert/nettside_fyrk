---
/**
 * Two modes section for the landing page
 * Shows advisory vs operational engagement models side by side
 */

interface Mode {
  label: string;
  title: string;
  description: string;
  characteristics: readonly string[];
  isHighlight: boolean;
}

interface Props {
  title: string;
  intro: string;
  modes: readonly Mode[];
  footnote: string;
  ctaText: string;
  ctaHref: string;
}

const { title, intro, modes, footnote, ctaText, ctaHref } = Astro.props;
---

<section id="moduser" class="py-16 md:py-20 px-6 bg-neutral-50 scroll-mt-20">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-h3 font-semibold text-brand-navy mb-4 text-center">
      {title}
    </h2>
    <p class="text-neutral-600 text-center mb-10 max-w-2xl mx-auto">
      {intro}
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {modes.map((mode) => (
        <div
          class:list={[
            'rounded-xl border p-6 md:p-8',
            mode.isHighlight
              ? 'bg-brand-navy text-white border-brand-navy shadow-lg'
              : 'bg-white text-neutral-700 border-neutral-200 shadow-sm',
          ]}
        >
          <p
            class:list={[
              'text-xs font-semibold uppercase tracking-wider mb-3',
              mode.isHighlight ? 'text-white/60' : 'text-neutral-400',
            ]}
          >
            {mode.label}
          </p>

          <h3
            class:list={[
              'text-h4 font-semibold mb-2',
              mode.isHighlight ? 'text-white' : 'text-brand-navy',
            ]}
          >
            {mode.title}
          </h3>

          <p
            class:list={[
              'mb-4',
              mode.isHighlight ? 'text-white/85' : 'text-neutral-600',
            ]}
          >
            {mode.description}
          </p>

          <ul class="space-y-2">
            {mode.characteristics.map((item) => (
              <li class="flex items-start gap-2 text-sm">
                <svg
                  class:list={[
                    'w-4 h-4 flex-shrink-0 mt-0.5',
                    mode.isHighlight ? 'text-white/50' : 'text-brand-navy/40',
                  ]}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class:list={[mode.isHighlight ? 'text-white/80' : 'text-neutral-600']}>
                  {item}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="text-sm text-neutral-500 text-center mt-8 italic">
      {footnote}
    </p>

    <div class="text-center mt-6">
      <a href={ctaHref} class="btn btn-outline no-underline" data-track-button="modes_cta">
        {ctaText}
      </a>
    </div>
  </div>
</section>
