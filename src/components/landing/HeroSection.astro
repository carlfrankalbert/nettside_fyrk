---
/**
 * Hero section for the landing page
 * Features headline, dual CTAs, and optional tagline
 */

interface Props {
  headline: string;
  description: string;
  ctaText: string;
  ctaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  tagline?: string;
}

const { headline, description, ctaText, ctaHref, secondaryCtaText, secondaryCtaHref, tagline } = Astro.props;
---

<section class="py-[120px] md:py-[140px] px-6 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">
  <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-[0.03]" aria-hidden="true">
    <defs>
      <pattern id="dot-grid" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1" fill="currentColor" />
      </pattern>
    </defs>
    <rect x="50%" y="0" width="50%" height="100%" fill="url(#dot-grid)" />
  </svg>

  <div class="max-w-4xl mx-auto flex flex-col items-center text-center relative z-10">
    <h1 class="text-h2 sm:text-h1 md:text-display font-bold text-brand-navy leading-[1.15] md:text-balance max-w-4xl">
      {headline}
    </h1>

    <p class="text-lg md:text-xl text-neutral-600 mt-5 max-w-[650px] leading-relaxed">
      {description}
    </p>

    <div class="mt-8 flex flex-col sm:flex-row gap-4">
      <a href={ctaHref} class="btn btn-primary px-8 py-4 text-lg no-underline" data-track-button="hero_cta">
        {ctaText}
      </a>
      {secondaryCtaText && secondaryCtaHref && (
        <a
          href={secondaryCtaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline no-underline"
          aria-label={`${secondaryCtaText} (åpnes i ny fane)`}
          data-track-button="hero_secondary_cta"
        >
          {secondaryCtaText}
        </a>
      )}
    </div>

    {tagline && (
      <p class="mt-10 text-sm text-neutral-500 tracking-wide">
        {tagline}
      </p>
    )}
  </div>
</section>
