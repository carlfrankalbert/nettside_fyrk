---
/**
 * Contact section for the landing page
 * Displays contact methods: email, LinkedIn, phone
 */
import { PHONE_PARTS, PHONE_COUNTRY } from '../../utils/links';

interface Props {
  title: string;
  description: string;
  emailHref: string;
  emailLabel: string;
  linkedinHref: string;
  linkedinLabel: string;
  phoneLabel: string;
}

const { title, description, emailHref, emailLabel, linkedinHref, linkedinLabel, phoneLabel } = Astro.props;
---

<section id="kontakt" class="py-16 md:py-24 px-6 bg-brand-navy scroll-mt-20">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-h2 font-bold text-white mb-3">
      {title}
    </h2>
    <div class="w-12 h-1 bg-brand-cyan-darker mx-auto mb-6 rounded-full"></div>
    <p class="text-lg text-neutral-300 mb-8">
      {description}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={emailHref} class="btn btn-primary no-underline inline-flex" data-track-button="contact_email">
        {emailLabel}
      </a>
      <a
        href={linkedinHref}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline-light no-underline inline-flex"
        aria-label={`${linkedinLabel} (åpnes i ny fane)`}
        data-track-button="contact_linkedin"
      >
        {linkedinLabel}
      </a>
      <a
        id="contact-phone-btn"
        class="btn btn-outline-light no-underline inline-flex"
        aria-label="Ring oss"
        data-c={PHONE_COUNTRY}
        data-p={PHONE_PARTS.join(',')}
        data-track-button="contact_phone"
      >
        {phoneLabel}
      </a>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById('contact-phone-btn');
  if (el) {
    const c = el.dataset.c;
    const parts = (el.dataset.p ?? '').split(',');
    el.setAttribute('href', `tel:${c}${parts.join('')}`);
    el.removeAttribute('data-c');
    el.removeAttribute('data-p');
  }
</script>
