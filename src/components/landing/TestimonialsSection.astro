---
/**
 * Testimonials section displaying LinkedIn recommendations
 */

interface Testimonial {
  quote: string;
  name: string;
  role: string;
  context: string;
  situation?: string;
}

interface Props {
  title: string;
  testimonials: readonly Testimonial[];
  linkedinHref: string;
}

const { title, testimonials, linkedinHref } = Astro.props;
---

<section class="py-16 md:py-20 px-6 bg-white relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -left-1/4 top-1/3 w-[600px] h-[300px] bg-gradient-to-tr from-brand-navy/[0.03] to-transparent rotate-[-25deg] rounded-[100px]"></div>
  </div>

  <div class="max-w-4xl mx-auto relative z-10">
    <h2 class="text-h3 font-semibold text-brand-navy mb-10 text-center">
      {title}
    </h2>

    <div class="grid md:grid-cols-2 gap-6">
      {testimonials.map((testimonial) => (
        <blockquote class="bg-neutral-50 rounded-xl p-6 border border-neutral-100 relative">
          <svg class="absolute top-3 left-3 w-6 h-6 text-brand-navy/10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>

          {testimonial.situation && (
            <p class="text-xs text-neutral-400 italic pt-5 mb-2">
              {testimonial.situation}
            </p>
          )}

          <p class:list={['text-neutral-600 text-sm italic mb-4 leading-relaxed', !testimonial.situation && 'pt-5']}>
            &laquo;{testimonial.quote}&raquo;
          </p>

          <footer class="text-sm text-neutral-500">
            <span class="font-medium text-brand-navy">{testimonial.name}</span>
            <br />
            {testimonial.role} &middot; {testimonial.context}
          </footer>
        </blockquote>
      ))}
    </div>

    <p class="text-sm text-center mt-8">
      <a
        href={linkedinHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-brand-navy hover:text-brand-navy/80 transition-colors font-medium"
        data-track-button="testimonials_linkedin"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19M18.5 18.5V13.2A3.26 3.26 0 0 0 15.24 9.94C14.39 9.94 13.4 10.46 12.92 11.24V10.13H10.13V18.5H12.92V13.57C12.92 12.8 13.54 12.17 14.31 12.17A1.4 1.4 0 0 1 15.71 13.57V18.5H18.5M6.88 8.56A1.68 1.68 0 0 0 8.56 6.88C8.56 5.95 7.81 5.19 6.88 5.19A1.69 1.69 0 0 0 5.19 6.88C5.19 7.81 5.95 8.56 6.88 8.56M8.27 18.5V10.13H5.5V18.5H8.27Z"/>
        </svg>
        Se alle anbefalinger på LinkedIn
      </a>
    </p>
  </div>
</section>
