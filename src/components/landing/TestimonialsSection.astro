---
/**
 * Testimonials section displaying LinkedIn recommendations
 */

interface Testimonial {
  quote: string;
  role: string;
  company: string;
  highlight?: string;
}

interface Props {
  title: string;
  testimonials: readonly Testimonial[];
}

const { title, testimonials } = Astro.props;
---

<section class="py-20 md:py-28 px-6 bg-neutral-50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-h2 font-semibold text-brand-navy mb-3 text-center">
      {title}
    </h2>
    <div class="w-16 h-1 bg-brand-cyan-darker mx-auto mb-10"></div>

    <div class="grid md:grid-cols-2 gap-6 items-stretch">
      {testimonials.map((testimonial) => (
        <blockquote class="bg-white rounded-xl p-8 border-l-4 border-brand-cyan-darker shadow-sm flex flex-col">
          {testimonial.highlight && (
            <p class="text-xl font-semibold text-brand-navy mb-3 leading-snug">
              &laquo;{testimonial.highlight}&raquo;
            </p>
          )}

          <p class="text-neutral-600 text-base leading-relaxed flex-1">
            &laquo;{testimonial.quote}&raquo;
          </p>

          <footer class="border-t border-neutral-200 mt-6 pt-4 text-sm text-neutral-500">
            <span class="font-medium text-brand-navy">{testimonial.role}</span> &middot; {testimonial.company}
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
